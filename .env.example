# ─────────────────────────────────────────────
# SUPABASE (free tier — supabase.com)
# ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# AI — Google Gemini (free tier — aistudio.google.com)
# ─────────────────────────────────────────────
GEMINI_API_KEY=
# gemini-2.0-flash was deprecated and shut down June 1, 2026 — use 2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────
# META (Instagram + Facebook) — developers.facebook.com
# Per-client tokens live in Supabase (clients table),
# these are only used for local testing of a single client.
# ─────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=replace-with-any-random-string

# ─────────────────────────────────────────────
# YOUTUBE DATA API — console.cloud.google.com
# Per-client OAuth tokens live in Supabase; these are
# only used for local single-client testing.
# ─────────────────────────────────────────────
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# ─────────────────────────────────────────────
# GOOGLE BUSINESS PROFILE API
# Same OAuth client as YouTube can be reused (Google Cloud project)
# ─────────────────────────────────────────────
GBP_OAUTH_CLIENT_ID=
GBP_OAUTH_CLIENT_SECRET=

# ─────────────────────────────────────────────
# CRON / WEBHOOK SECURITY
# Random strings you generate yourself. Used to verify
# requests to /api/cron/* actually come from your cron pinger.
# ─────────────────────────────────────────────
CRON_SECRET=replace-with-any-random-string
